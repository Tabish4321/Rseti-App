<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- 🔹 Profile Image -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/candidateImage"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CustomCircleShape"
            app:strokeColor="@color/color_dark_green"
            app:strokeWidth="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- 🔹 Right Container -->
        <LinearLayout
            android:id="@+id/rightContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/candidateImage"
            app:layout_constraintTop_toTopOf="@id/candidateImage"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 🔹 ROW 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp">

                <TextView
                    android:id="@+id/tvBatchRegno"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="@string/batch_id"
                    android:textColor="@color/color_follow_up_title"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvtvBatchRegNoValue"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:text="@string/batch_id"
                    android:textStyle="bold"
                    android:textColor="@color/color_text"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"/>

            <!-- 🔹 ROW 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp">

                <TextView
                    android:id="@+id/tvRollNumber"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/roll_no"
                    android:textColor="@color/color_follow_up_title"/>

                <TextView
                    android:id="@+id/tvRollNumberValue"
                    android:text="@string/roll_no"
                    android:textStyle="bold"
                    android:textColor="@color/color_text"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

            <!-- 🔹 ROW 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp">

                <TextView
                    android:id="@+id/tvCandidate"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/name"
                    android:textColor="@color/color_follow_up_title"/>

                <TextView
                    android:id="@+id/tvCandidateName"
                    android:text="@string/candidate_name"
                    android:textStyle="bold"
                    android:textColor="@color/color_text"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

            <!-- 🔹 ROW 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp">

                <TextView
                    android:id="@+id/tvCandidateId"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/candidate_id"
                    android:textColor="@color/color_follow_up_title"/>

                <TextView
                    android:id="@+id/tvCandidateIdValue"
                    android:text="@string/candidate_id"
                    android:textStyle="bold"
                    android:textColor="@color/color_text"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

            <!-- 🔹 ROW 5 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp">

                <TextView
                    android:id="@+id/tvContact"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/contact_number"
                    android:textColor="@color/color_follow_up_title"/>

                <TextView
                    android:id="@+id/tvContactNumber"
                    android:text="@string/contact_number"
                    android:textStyle="bold"
                    android:textColor="@color/color_text"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

            <!-- 🔹 ROW 6 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp">

                <TextView
                    android:id="@+id/tvguardianContact"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/guardian_ph_no"
                    android:textColor="@color/color_follow_up_title"/>

                <TextView
                    android:id="@+id/tvguardianContactValue"
                    android:text="@string/guardian_ph_no"
                    android:textStyle="bold"
                    android:textColor="@color/color_text"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

            <!-- 🔹 ROW 7 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp">

                <TextView
                    android:id="@+id/tvsettledOn"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/settled_on"
                    android:textColor="@color/color_follow_up_title"/>

                <TextView
                    android:id="@+id/tvsettledOnValue"
                    android:text="@string/settled_on"
                    android:textStyle="bold"
                    android:textColor="@color/color_text"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

            <!-- 🔹 ROW 8 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp">

                <TextView
                    android:id="@+id/tvverificationStatus"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/verification_status"
                    android:textColor="@color/color_follow_up_title"/>

                <TextView
                    android:id="@+id/tvverificationStatusValue"
                    android:text="@string/verification_status"
                    android:textStyle="bold"
                    android:textColor="@color/color_text"/>
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>






